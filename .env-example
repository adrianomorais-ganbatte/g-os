WEEKLY_UPDATE=TRUE # or FALSE

# Modo de escrita do weekly-update. Valores: simple | detailed
# - simple: linguagem acessivel, sem jargao tecnico (alinhado ao pedido da PO/PM)
# - detailed: relatorio executivo com IDs de task e termos tecnicos
# Se ausente, skill cai para detailed.
WEEKLY_UPDATE_MODE=simple

SLACK_WEBHOOK_URL=
SLACK_WEBHOOK_CSPO_TECH=
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID_WEEKLY=

# ClickUp personal API token. Get yours at:
# https://app.clickup.com/settings/apps (section "API Token")
# Used by ClickUp MCP server and .gos/scripts/tools/clickup.js
CLICKUP_API_KEY=
