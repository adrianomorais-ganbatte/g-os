{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://a8z.dev/schemas/sprint-clickup.schema.json",
  "title": "Sprint ClickUp Schema",
  "description": "Schema para validar dados estruturados de sprint para importação no ClickUp",
  "type": "object",
  "required": ["version", "sprint", "tasks"],
  "properties": {
    "version": { "type": "string", "const": "1.0" },
    "sprint": {
      "type": "object",
      "required": ["id", "name", "startDate", "endDate"],
      "properties": {
        "id": { "type": "string", "pattern": "^S\\d{2}$" },
        "name": { "type": "string", "minLength": 1 },
        "startDate": { "type": "string", "format": "date" },
        "endDate": { "type": "string", "format": "date" },
        "durationDays": { "type": "integer", "minimum": 1 },
        "clickupFolderId": { "type": "string" },
        "clickupSpaceId": { "type": "string" },
        "status": { "enum": ["planning", "active", "review", "closed"] },
        "tags": { "type": "array", "items": { "type": "string" } }
      }
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "track"],
        "properties": {
          "id": { "type": "integer" },
          "name": { "type": "string" },
          "track": { "enum": ["backend", "frontend", "qa", "devops", "general"] },
          "clickupListId": { "type": "string" },
          "tasks": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "priority"],
        "properties": {
          "id": { "type": "string", "pattern": "^T-\\d{3}$" },
          "ref": { "type": "string" },
          "title": { "type": "string", "minLength": 1 },
          "description": { "type": "string" },
          "phase": { "type": "integer" },
          "priority": { "enum": ["P0", "P1", "P2"] },
          "points": { "type": "integer", "minimum": 1, "maximum": 13 },
          "status": { "enum": ["todo", "in-progress", "review", "done", "blocked"] },
          "area": { "enum": ["backend", "frontend", "qa", "devops", "general"] },
          "track": { "enum": ["backend", "frontend", "qa", "devops", "general"] },
          "clickupTaskId": { "type": "string" },
          "businessRules": { "type": "array", "items": { "type": "string" } },
          "acceptanceCriteria": { "type": "array", "items": { "type": "string" } },
          "dependencies": { "type": "array", "items": { "type": "string" } },
          "files": { "type": "array", "items": { "type": "string" } },
          "context": { "type": "string", "description": "Contexto de negócio — por que esta task existe, motivação para leitor não-técnico" },
          "steps": { "type": "array", "items": { "type": "string" }, "description": "Passo a passo de implementação (3-7 steps acionáveis)" },
          "technicalNotes": { "type": "string", "description": "Notas técnicas, decisões de arquitetura, caveats" },
          "estimatedHours": { "type": "number", "minimum": 0.5, "maximum": 16, "description": "Estimativa em horas (0.5-16)" },
          "dod": { "type": "string", "description": "Definition of Done — como verificar que está pronto" },
          "subtasks": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["id", "title"],
              "properties": {
                "id": { "type": "string" },
                "title": { "type": "string" },
                "description": { "type": "string" },
                "clickupTaskId": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "businessRules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "description"],
        "properties": {
          "id": { "type": "string", "pattern": "^BR-" },
          "description": { "type": "string" }
        }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "type"],
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "type": { "enum": ["blocks", "relates-to", "requires"] }
        }
      }
    }
  }
}
